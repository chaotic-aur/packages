#!/bin/bash

post_install() {
    update-mime-database /usr/share/mime || true
    update-desktop-database /usr/share/applications || true
}

post_remove() {
    update-mime-database /usr/share/mime || true
    update-desktop-database /usr/share/applications || true
    # remove legacy symlink from older package versions
    rm -f /usr/local/bin/electron-mail    
}
