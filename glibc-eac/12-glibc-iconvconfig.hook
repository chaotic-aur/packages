[Trigger]
Operation = Install
Operation = Upgrade
Target = glibc
Type = Package

[Trigger]
Operation = Install
Operation = Upgrade
Target = usr/lib/gconv/gconv-modules
Type = Path

[Trigger]
Operation = Install
Operation = Remove
Operation = Upgrade
Target = usr/lib/gconv/gconv-modules.d/*
Type = Path

[Action]
Depends = glibc
Description = Creating inconv module configuration cache...
Exec = /usr/bin/iconvconfig
When = PostTransaction
