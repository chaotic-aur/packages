pkgbase = claude-cowork-service
	pkgdesc = Native Linux backend for Claude Desktop Cowork
	pkgver = 1.1.0
	pkgrel = 1
	url = https://github.com/patrickjaja/claude-cowork-service
	install = claude-cowork-service.install
	arch = x86_64
	arch = aarch64
	license = MIT
	makedepends = go
	depends = util-linux
	optdepends = claude-desktop-bin: Unofficial Linux frontend for Claude Desktop Cowork
	optdepends = claude-code: An agentic coding tool that lives in your terminal (you can also install via native installer)
	optdepends = systemd: required for the systemd user service unit (provided by base on Arch)
	optdepends = openrc: required to use the OpenRC init script (Artix Linux)
	options = !debug
	backup = etc/conf.d/claude-cowork
	source = claude-cowork-service-1.1.0.tar.gz::https://github.com/patrickjaja/claude-cowork-service/archive/v1.1.0.tar.gz
