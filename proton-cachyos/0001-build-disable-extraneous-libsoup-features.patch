From 4bfaadba8279541db42f09f449f3b56272b4369f Mon Sep 17 00:00:00 2001
From: Stelios Tsampas <loathingkernel@gmail.com>
Date: Mon, 4 May 2026 14:08:20 +0300
Subject: [PATCH] build: disable extraneous libsoup features

---
 Makefile.in | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/Makefile.in b/Makefile.in
index 11503d094..84dcf7771 100644
--- a/Makefile.in
+++ b/Makefile.in
@@ -302,6 +302,11 @@ LIBSOUP_MESON_ARGS = \
 	-Dautobahn=disabled \
 	-Dtls_check=false
 
+LIBSOUP_MESON_ARGS += \
+	-Dntlm=disabled \
+	-Dintrospection=disabled \
+	-Dtests=false
+
 LIBSOUP_DEPENDS = nghttp2
 
 $(eval $(call rules-source,libsoup,$(SRCDIR)/libsoup))
-- 
2.54.0

