Date: Sun, 26 Apr 2026 18:38:19 +0200
Subject: [PATCH 4/4] Remove Qt version requirements

---
 phoenix.pro | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/phoenix.pro b/phoenix.pro
index 433a1da9..3bf53990 100644
--- a/phoenix.pro
+++ b/phoenix.pro
@@ -18,11 +18,6 @@
 #
 # ********************************************************************
 
-QT_LEAST=6.5.3
-QT_MOST=6.10.10
-!versionAtLeast(QT_VERSION, $${QT_LEAST}):error("Use at least Qt version $${QT_LEAST}")
-!versionAtMost(QT_VERSION, $${QT_MOST}):error("Use at most Qt version $${QT_MOST}")
-
 CONFIG += debug_and_release
 CONFIG += c++20
 
