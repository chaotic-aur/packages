pkgname=gcdemu
pkgver=3.3.1
pkgrel=1
pkgdesc="GNOME panel applet controlling cdemu-daemon"
arch=('any')
url="http://cdemu.sourceforge.net/"
license=(GPL-2.0-only)
depends=(cdemu-daemon python python-gobject gdk-pixbuf2 glib2 gtk3 libappindicator libnotify)
makedepends=(cmake intltool)
source=("https://downloads.sourceforge.net/cdemu/$pkgname-$pkgver.tar.xz")
sha256sums=('cc1459c5b4fe27ce6931361a4d1c6b577b9aeb59ba29853a692b697a085876f6')

build() {
  mkdir "$srcdir/build"
  cd "$srcdir/build"
  cmake -DPOST_INSTALL_HOOKS=off -DCMAKE_INSTALL_PREFIX=/usr ../"$pkgname-$pkgver"
  make
}

package() {
  cd "$srcdir/build"
  make DESTDIR="$pkgdir" install
}
