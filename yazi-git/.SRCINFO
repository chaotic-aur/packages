pkgbase = yazi-git
	pkgdesc = Blazing fast terminal file manager written in Rust, based on async I/O
	pkgver = 26.5.6.r47.gc92c4ab
	pkgrel = 2
	url = https://github.com/sxyazi/yazi
	arch = x86_64
	arch = aarch64
	license = MIT
	makedepends = cargo
	makedepends = git
	makedepends = imagemagick
	depends = hicolor-icon-theme
	depends = lua
	depends = oniguruma
	depends = ttf-font-nerd
	optdepends = 7zip: for archive extraction and preview
	optdepends = chafa: for ASCII image preview as fallback
	optdepends = fd: for file searching
	optdepends = ffmpeg: for video thumbnails
	optdepends = fzf: for quick file subtree navigation
	optdepends = git: for Yazi package management
	optdepends = imagemagick: for image and font preview
	optdepends = jq: for JSON preview
	optdepends = poppler: for PDF preview
	optdepends = resvg: for SVG preview
	optdepends = ripgrep: for file content searching
	optdepends = wl-clipboard: for Wayland clipboard support
	optdepends = xclip: for X11 clipboard support
	optdepends = xsel: for X11 clipboard support
	optdepends = zoxide: for historical directories navigation
	provides = yazi
	conflicts = yazi
	options = !lto
	source = yazi::git+https://github.com/sxyazi/yazi.git
	sha256sums = SKIP

pkgname = yazi-git
