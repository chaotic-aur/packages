# NOTE on building this package:
# * Go to the trunk/ directory
# * Run bash -c ". PKGBUILD; updatelist"
# * Update the checksums, update pkgver
# * Build the package

updatelist() {
  rm -f mirrorlist
  curl -o mirrorlist "https://mirrorlist.chaotic.cx/mirrorlist.txt"
}

pkgname=chaotic-mirrorlist
pkgver=20260406
pkgrel=1
pkgdesc="Chaotic-AUR mirrorlist to use with Pacman"
url="https://aur.chaotic.cx"
license=('GPL')
arch=('any')

backup=(etc/pacman.d/chaotic-mirrorlist)
source=(mirrorlist)
sha256sums=('e69d8fb91574fad2079f185bdab2e78186ea93e4fd09c26a675a1eeaea027400')

package() {
  mkdir -p "$pkgdir/etc/pacman.d"
  install -m644 "$srcdir/mirrorlist" "$pkgdir/etc/pacman.d/chaotic-mirrorlist"
}
