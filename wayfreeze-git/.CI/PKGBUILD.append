_units=$(($(nproc) > 16 ? $(nproc) : 16))
export RUSTFLAGS="-C opt-level=2 -C codegen-units=$_units -C lto=off"

license=('AGPL-3.0-only')

options=('!lto')

provides=(wayfreeze)
conflicts=(wayfreeze)

_pkgsrc="$_pkgname"
pkgver() {
  cd "$_pkgsrc"
  git describe --long --tags --abbrev=7 --exclude='*[a-zA-Z][a-zA-Z]*' \
    | sed -E 's/^[^0-9]*//;s/([^-]*-g)/r\1/;s/-/./g'
}
