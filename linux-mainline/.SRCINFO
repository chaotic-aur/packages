pkgname = linux-mainline
	pkgdesc = The Linux Mainline kernel and modules
	depends = coreutils
	depends = initramfs
	depends = kmod
	optdepends = linux-mainline-headers: headers and scripts for building modules
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = scx-scheds: to use sched-ext schedulers
	optdepends = wireless-regdb: to set the correct wireless channels of your country
	provides = KSMBD-MODULE
	provides = NTSYNC-MODULE
	provides = VIRTUALBOX-GUEST-MODULES
	provides = WIREGUARD-MODULE
	replaces = virtualbox-guest-modules-arch
	replaces = wireguard-arch

pkgname = linux-mainline-headers
	pkgdesc = Headers and scripts for building modules for the Linux Mainline kernel
	depends = binutils
	depends = glibc
	depends = libelf
	depends = libgcc
	depends = openssl
	depends = pahole
	depends = xxhash
	depends = zlib
	depends = zstd
	provides = LINUX-HEADERS

pkgname = linux-mainline-docs
	pkgdesc = Documentation for the Linux Mainline kernel
