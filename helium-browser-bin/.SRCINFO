pkgbase = helium-browser-bin
	pkgdesc = Private, fast, and honest web browser based on Chromium (Latest/Stable)
	pkgver = 0.12.3.1
	pkgrel = 1
	url = https://github.com/imputnet/helium-linux
	arch = x86_64
	arch = aarch64
	license = GPL-3.0-only AND BSD-3-Clause
	depends = alsa-lib
	depends = dbus
	depends = gtk3
	depends = hicolor-icon-theme
	depends = libcups
	depends = libpulse
	depends = libva
	depends = libxss
	depends = nss
	depends = ttf-liberation
	depends = udev
	depends = xdg-utils
	optdepends = pipewire: WebRTC desktop sharing under Wayland
	optdepends = kdialog: support for native dialogs in Plasma
	optdepends = org.freedesktop.secrets: password storage backend on GNOME / Xfce
	optdepends = kwallet: support for storing passwords in KWallet on Plasma
	optdepends = qt5-base: support for Qt themes
	optdepends = upower: Battery Status API support
	provides = helium-browser-beta-bin=0.12.3.1
	conflicts = helium-browser-beta-bin
	options = !strip
	source = 0001-update-wrapper-arch.patch
	source = 0002-align-desktop-entry.patch
