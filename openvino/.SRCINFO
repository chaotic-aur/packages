	depends = intel-npu-compiler
	depends = intel-npu-driver
	depends = libgcc
	depends = libstdc++
	depends = onetbb
	depends = opencv
	depends = openvino=2026.2.1
	depends = pugixml

pkgname = python-openvino
	pkgdesc = Python bindings for OpenVINO
