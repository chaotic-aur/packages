	conflicts = intel-openvino
	replaces = intel-openvino

pkgname = openvino-intel-gpu-plugin
	pkgdesc = Intel GPU plugin for OpenVINO
	depends = glibc
	depends = intel-compute-runtime
	depends = libgcc
	depends = libstdc++
	depends = ocl-icd
	depends = onetbb
	depends = openvino=2026.2.1
	depends = pugixml

