pkgname = openvino
	depends = glibc
	depends = libgcc
	depends = libstdc++
	depends = onetbb
	depends = pugixml
	depends = snappy
	optdepends = openvino-intel-gpu-plugin: for Intel GPU plugin
	optdepends = openvino-intel-npu-plugin: for Intel NPU plugin
